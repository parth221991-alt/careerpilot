# ── Supabase ──────────────────────────────────────────────────────────────────
# From: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — server-side only, bypasses RLS (Prisma uses this)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Prisma database connection strings
# From: Supabase → Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voyage AI (embeddings) ────────────────────────────────────────────────────
# From: https://dash.voyageai.com
VOYAGE_API_KEY=pa-...

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Local: http://localhost:6333 (run: docker run -p 6333:6333 qdrant/qdrant)
# Cloud: https://YOUR_CLUSTER_ID.us-east4-0.gcp.cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379 (run: docker run -p 6379:6379 redis:alpine)
# Cloud: Upstash or Railway
REDIS_URL=redis://localhost:6379

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
# From: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Redirect URI to add: http://localhost:3003/api/email/oauth/callback
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Adzuna Jobs API ───────────────────────────────────────────────────────────
# From: https://developer.adzuna.com → Register for API access
# Used for Adzuna job scraping (REQ-023)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── JSearch (RapidAPI) ────────────────────────────────────────────────────────
# From: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch → Subscribe
# Used for JSearch remote job discovery (REQ-023)
RAPIDAPI_KEY=

# ── Naukri session setup ─────────────────────────────────────────────────────
# Your CareerPilot user UUID — required to run: npx tsx workers/scrapers/naukri-login.ts
# Find it in Supabase → Authentication → Users → your row → ID
NAUKRI_USER_ID=

# Playwright apply worker inter-apply delays (milliseconds)
# 180000 = 3 minutes minimum | 480000 = 8 minutes maximum
NAUKRI_MIN_DELAY_MS=180000
NAUKRI_MAX_DELAY_MS=480000

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3003
